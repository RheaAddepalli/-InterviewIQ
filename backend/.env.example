# ── LLM (Ollama) ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_interviewer

# ── Interview config ─────────────────────────────────────────
MAX_QUESTIONS=10

# ── RAG ──────────────────────────────────────────────────────
CHUNK_SIZE=600
CHUNK_OVERLAP=100
TOP_K_RETRIEVE=8
RERANK_TOP_K=5
